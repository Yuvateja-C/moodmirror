body {
    font-family: Arial, sans-serif;
    background: #0f172a;
    color: white;
    text-align: center;
}

.container {
    margin-top: 100px;
}

textarea {
    width: 300px;
    height: 100px;
    border-radius: 10px;
    padding: 10px;
}

button {
    margin-top: 10px;
    padding: 10px 20px;
    background: #38bdf8;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}

.result {
    margin-top: 20px;
}

.line {
    font-style: italic;
    color: #facc15;
}
