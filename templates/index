<!DOCTYPE html>
<html>
<head>
    <title>MoodMirror</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>

<div class="container">
    <h1>MoodMirror</h1>
    <p>Type how you feel...</p>

    <form method="POST">
        <textarea name="text" placeholder="I'm feeling..." required></textarea>
        <button type="submit">Reflect</button>
    </form>

    {% if result %}
        <div class="result">
            <h2>Mood: {{ result.mood }}</h2>
            <p class="line">"{{ result.line }}"</p>
            <p><b>Try this:</b> {{ result.action }}</p>
        </div>
    {% endif %}
</div>

</body>
</html>
